{
  "name": "jupyterlab-vtl-2-1",
  "version": "0.1.0",
  "description": "VTL 2.1 editor support for JupyterLab (Trevas kernel cells)",
  "author": "Making Sense Info",
  "homepage": "https://github.com/Making-Sense-Info/Trevas-Jupyter",
  "repository": {
    "type": "git",
    "url": "https://github.com/Making-Sense-Info/Trevas-Jupyter.git"
  },
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "vtl",
    "trevas"
  ],
  "license": "MIT",
  "files": [
    "lib/**/*.{d.ts,js,js.map}",
    "style/**/*.{css,js}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "scripts": {
    "build": "yarn run build:lib && yarn run build:labextension",
    "build:prod": "yarn run clean && yarn run build:lib && yarn run build:labextension",
    "build:lib": "tsc --sourceMap",
    "build:labextension": "jupyter labextension build .",
    "clean": "yarn run clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/lint": "^6.9.0",
    "@jupyterlab/application": "~4.4.10",
    "@jupyterlab/apputils": "~4.4.8",
    "@jupyterlab/cells": "~4.4.10",
    "@jupyterlab/codemirror": "~4.4.10",
    "@jupyterlab/coreutils": "~6.4.10",
    "@jupyterlab/docregistry": "~4.4.10",
    "@jupyterlab/notebook": "~4.4.10",
    "@lezer/highlight": "^1.2.0",
    "@making-sense/antlr4ng": "^3.0.4",
    "@making-sense/vtl-2-1-antlr-tools-ts": "^1.0.5"
  },
  "devDependencies": {
    "@jupyterlab/builder": "~4.4.10",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.0",
    "typescript": "~5.8.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "yarn@3.5.0",
  "resolutions": {
    "webpack": "5.106.2",
    "@jupyterlab/application": "4.4.10",
    "@jupyterlab/apputils": "4.4.8",
    "@jupyterlab/cells": "4.4.10",
    "@jupyterlab/codemirror": "4.4.10",
    "@jupyterlab/coreutils": "6.4.10",
    "@jupyterlab/docregistry": "4.4.10",
    "@jupyterlab/notebook": "4.4.10",
    "@jupyterlab/builder": "4.4.10"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_vtl_2_1/labextension",
    "sharedPackages": {
      "@codemirror/autocomplete": {
        "bundled": true,
        "singleton": true
      },
      "@codemirror/lint": {
        "bundled": true,
        "singleton": false
      },
      "@making-sense/antlr4ng": {
        "bundled": true
      },
      "@making-sense/vtl-2-1-antlr-tools-ts": {
        "bundled": true
      }
    }
  }
}
